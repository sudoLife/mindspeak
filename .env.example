OPENAI_API_KEY=

# OpenAI models. Override these as your account/model availability changes.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# Optional transcription hints.
OPENAI_TRANSCRIPTION_LANGUAGE=
OPENAI_TRANSCRIPTION_PROMPT=

# MindSpeak note behavior.
MINDSPEAK_INCLUDE_TRANSCRIPT=true
MINDSPEAK_TAGS=voice,mindspeak
MINDSPEAK_TEMPLATE_TAG_LINE=Tags: [[Voice note]]
MINDSPEAK_SUMMARY_PROMPT=Extract the core idea from this walking voice note. Name the idea clearly with a short human-readable title using spaces, then produce concise sections for summary, strengths, risks, and next action.

# Obsidian write mode: "file" writes directly to your vault path; "mcp" calls a stdio MCP tool.
OBSIDIAN_WRITE_MODE=mcp
OBSIDIAN_VAULT_PATH=/path/to/your/Obsidian/Vault
OBSIDIAN_VOICE_FOLDER=Voice

# MCP mode configuration for the Obsidian MCP Tools plugin.
# Keep the real OBSIDIAN_API_KEY in .env only; do not commit it.
OBSIDIAN_MCP_COMMAND=/path/to/obsidian-mcp-server
OBSIDIAN_API_KEY=
OBSIDIAN_MCP_REQUIRED_ENV=OBSIDIAN_API_KEY
OBSIDIAN_MCP_TOOL=execute_template
OBSIDIAN_MCP_TEMPLATE=Templates/Voice note template.md
OBSIDIAN_MCP_PATCH_TOOL=patch_vault_file
OBSIDIAN_MCP_EXTRA_ARGS={}
